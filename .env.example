OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_CONFIG_DIR=./.openclaw
OPENCLAW_WORKSPACE_DIR=./workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token

# Discord
DISCORD_BOT_TOKEN=
DISCORD_SERVER_ID=
DISCORD_OWNER_USER_ID=
DISCORD_VD_MANAGER_CHANNEL_ID=

# Google Drive data for the document-management skill
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_PROVISION_ON_START=false
NATIVE_GOOGLE_CONNECTORS_ENABLED=false
# Native Google OAuth is disabled in the Maton-only setup.

# Optional skill env
MATON_API_KEY=
MATON_GOOGLE_DRIVE_CONNECTION_ID=
MATON_GMAIL_CONNECTION_ID=
INGESTION_SHARED_SECRET=
DEFAULT_APPROVER_DISCORD_ID=
# L'analyse documentaire automatisee tourne en local.
# Un compte ChatGPT/Codex ne fournit pas d'API exploitable par ce backend.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
DISCORD_FINANCE_CHANNEL_ID=
DISCORD_LOGISTICS_CHANNEL_ID=
DISCORD_CONTRACTS_CHANNEL_ID=
DISCORD_INGEST_CHANNEL_IDS=
GMAIL_INGEST_ENABLED=false
GMAIL_INGEST_QUERY=has:attachment is:unread
GOOGLE_DRIVE_INGEST_FOLDER_IDS=
GOOGLE_DRIVE_CRAWLER_ENABLED=false
GOOGLE_DRIVE_CRAWLER_FOLDER_IDS=
GOOGLE_DRIVE_CRAWLER_BATCH_SIZE=50
GOOGLE_DRIVE_CRAWLER_CRON=*/15 * * * *
GOOGLE_DRIVE_CRAWLER_REPORT_CRON=0 18 * * *
GOOGLE_DRIVE_CRAWLER_REPORT_TIMEZONE=Europe/Paris
CONNECTOR_POLL_INTERVAL_MS=30000
ENABLE_VISION_OCR=false
VISION_MAX_RENDERED_PAGES=4
ENABLE_PADDLE_OCR=true
PADDLE_OCR_LANG=fr
MANUAL_DEPOT_DIR=workspace/inbound/manual-depot
PROCESSED_DEPOT_DIR=workspace/inbound/processed
DOCUMENT_STORAGE_DIR=.openclaw/media/inbound
DOCUMENT_MAX_FILE_SIZE_MB=75
